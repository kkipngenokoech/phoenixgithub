# ── GitHub ──────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=owner/repo-name

# ── Polling ─────────────────────────────────────────
POLL_INTERVAL=60
MAX_CONCURRENT_RUNS=2

# ── LLM ─────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=              # optional: custom endpoint

# ── LangSmith (Tracing) ─────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_langsmith_api_key
LANGCHAIN_PROJECT=phoenix-${GITHUB_REPO}
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Agent ───────────────────────────────────────────
TEST_COMMAND=pytest --import-mode=importlib --rootdir=.
# BUILD_COMMAND=             # optional: build step
AUTO_REVISE_ON_TEST_FAILURE=true
AUTO_REVISE_MAX_CYCLES=3
NO_PROGRESS_ROOT_CAUSE_REPEAT_LIMIT=2
REVISE_INCREMENTAL=true
ALLOW_NO_TESTS=false
VALIDATION_PROFILE=auto

# ── Paths ───────────────────────────────────────────
WORKSPACE_DIR=./workspace
STATE_FILE=./.watcher-state.json
LOG_LEVEL=INFO
